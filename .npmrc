# --------------------------------------------------
# PNPM SETTINGS FOR MONOREPO
# --------------------------------------------------

# Use classic node_modules (max compatibility)
node-linker=hoisted

# Automatically install missing peerDependencies
auto-install-peers=true

# Prevent pnpm from creating a lockfile in sub-packages
shared-workspace-lockfile=true

# Enforce a single version of each package across workspace
strict-peer-dependencies=false

# --------------------------------------------------
# HOIST FIXES FOR LIBRARIES THAT BREAK WITH STRICT STRUCTURE
# --------------------------------------------------

# UI / Babel / Metro bundler compatibility
public-hoist-pattern[]=*@babel*
public-hoist-pattern[]=*@nextui-org/*
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=react-native
public-hoist-pattern[]=webpack

# --------------------------------------------------
# REGISTRY DEFAULT (OPTIONAL)
# --------------------------------------------------
registry=https://registry.npmjs.org/

# --------------------------------------------------
# SAVE PREFIX FOR VERSIONS (~ or ^)
# --------------------------------------------------
save-prefix="^"
engine-strict= true