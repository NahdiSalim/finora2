{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "SWIFTECH",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "tsx prisma/seed.ts",
    "seed:demo": "tsx prisma/seed-demo.ts",
    "seed:relationship": "tsx prisma/seed-relationship.ts",
    "test:report": "jest --verbose --silent --testPathPatterns=request.service.spec --testPathPatterns=task.service.spec --testPathPatterns=chat.gateway.spec --testPathPatterns=chat.service.spec --testPathPatterns=notification.service.spec",
    "test:report:soumettre": "jest --verbose --silent --testPathPatterns=request.service.spec -t \"3.6.1\"",
    "test:report:convertir": "jest --verbose --silent --testPathPatterns=request.service.spec -t \"3.6.2\"",
    "test:report:statut": "jest --verbose --silent --testPathPatterns=task.service.spec -t \"3.6.3\"",
    "test:report:message": "jest --verbose --silent --testPathPatterns=chat.gateway.spec -t \"4.6.1\"",
    "test:report:groupe": "jest --verbose --silent --testPathPatterns=chat.service.spec -t \"4.6.2\"",
    "test:report:notifications": "jest --verbose --silent --testPathPatterns=notification.service.spec -t \"4.6.3\"",
    "test:report:totaux": "jest --verbose --silent --testPathPatterns=invoice.service.spec -t \"5.6.1\"",
    "test:report:devis-facture": "jest --verbose --silent --testPathPatterns=devis.service.spec -t \"5.6.2\"",
    "test:report:pdf": "jest --verbose --silent --testPathPatterns=invoice.service.spec -t \"5.6.3\"",
    "test:report:bl-facture": "jest --verbose --silent --testPathPatterns=bon-livraison.service.spec -t \"5.6.4\""
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/swagger": "^11.2.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.14",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.4.0",
    "@types/minio": "^7.1.1",
    "@types/pdfkit": "^0.17.5",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "country-state-city": "^3.2.1",
    "csv": "^6.4.1",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^8.2.1",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.6",
    "nestjs-pino": "^4.5.0",
    "nodemailer": "^7.0.12",
    "nodemailer-smtp-transport": "^2.7.4",
    "openai": "^6.39.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pino-http": "^11.0.0",
    "puppeteer": "^23.11.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.5",
    "@types/nodemailer-smtp-transport": "^2.7.8",
    "@types/passport-jwt": "^4.0.1",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.4.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^prisma/(.*)$": "<rootDir>/../prisma/$1",
      "^src/(.*)$": "<rootDir>/$1"
    }
  }
}
