model Notification {
  id          Int       @id @default(autoincrement())
  recipientId Int
  type        String    // "request" | "task" | "meeting" | "message" | "system"
  title       String
  message     String
  data        String?   @db.Text // JSON with additional data
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  recipient   User      @relation("NotificationRecipient", fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([read])
  @@index([createdAt])
}
