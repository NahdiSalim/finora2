model p_tasks {
    role_id   Int
    task_id   Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    role Role  @relation(fields: [role_id], references: [id], onDelete: Cascade)
    task Tasks @relation(fields: [task_id], references: [id], onDelete: Cascade)

    @@id([role_id, task_id])
    @@index([task_id])
}
