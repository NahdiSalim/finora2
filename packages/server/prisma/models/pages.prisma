model Pages {
    id        Int      @id @default(autoincrement())
    PageUrl   String
    slug      String   @unique  
    featureId Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
    p_pages   p_pages[]
    actions   Action[]
}
