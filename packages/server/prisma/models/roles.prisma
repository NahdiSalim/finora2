model Role {
    id            Int          @id @default(autoincrement())
    nameFr        String
    nameEn        String
    descriptionEn String
    descriptionFr String
    createdAt     DateTime     @default(now())
    updatedAt     DateTime     @updatedAt
    p_pages       p_pages[]
    p_features    p_features[]
    p_tasks       p_tasks[]
    users         User[]

    @@unique([nameFr, nameEn])
}